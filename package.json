  "private": true,
  "scripts": {
    "start": "concurrently \"npm run start-server\" \"npm run start-front\" --kill-others --kill-others-on-fail",
    "start-server": "node backend/index.js",
    "start-front": "node scripts/wait-api-then-vite.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --runInBand --silent",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage",
    "dev": "npm start",
    "download-images": "node backend/scripts/downloadImages.js",
    "seed:products": "node backend/scripts/seedProducts.js",
    "seed:products:force": "node backend/scripts/seedProducts.js --force",
    "seed:reset": "node -e \"require('./backend/config/database').connectDB().then(async()=>{const m=require('mongoose');await m.connection.db.dropDatabase();console.log('Database dropped');process.exit(0)})\""
  },
  "browserslist": {
    "production": [
